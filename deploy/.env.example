# === 模型配置 ===
MODEL_NAME=qwen3-embedding-8b
# 宿主机上模型文件的目录（挂载到容器 /models）
MODEL_PATH=../../models
# 模型目录名（在 MODEL_PATH 内的子目录）
MODEL_DIR_NAME=Qwen3-Embedding-8B

# === GPU 配置 ===
CUDA_VISIBLE_DEVICES=2

# === vLLM 配置 ===
VLLM_PORT=8101
VLLM_DTYPE=float16
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90

# === Gateway 配置 ===
GATEWAY_PORT=8000
EMBEDDING_DIM=4096
MAX_INPUT_ITEMS=256
REQUEST_TIMEOUT_SECONDS=120
RETRY_ATTEMPTS=2
# 多个 key 用逗号分隔，留空表示不启用鉴权
API_KEYS=
QUERY_INSTRUCTION='Given a user query, retrieve relevant passages that answer the query.'

# === Qdrant（可选，需 --profile qdrant 启动） ===
QDRANT_PORT=6333
